# ============================================================
# SERVIDOR
# ============================================================
PORT=3600
NODE_ENV=development

# ============================================================
# BASE DE DATOS (MySQL)
# ============================================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_DATABASE=your_db_name

# ============================================================
# AUTENTICACIÓN (JWT)
# Usar cadenas largas y aleatorias. Nunca usar los mismos
# valores en producción y en desarrollo.
# ============================================================
JWT_SECRET=change_this_to_a_long_random_secret
JWT_REFRESH_SECRET=change_this_to_a_different_long_random_secret

# ============================================================
# CORS — URL del frontend permitido
# ============================================================
FRONTEND_URL=http://localhost:4200

# ============================================================
# ALMACENAMIENTO DE ARCHIVOS
# Ruta absoluta donde se guardarán los uploads (PDFs, etc.)
# Si no se define, se usa ./uploads relativo al directorio del proyecto.
# ============================================================
# UPLOAD_PATH=/ruta/absoluta/a/uploads

# ============================================================
# DATOS DE EMPRESA (para exportación de libros AEAT)
# ============================================================
COMPANY_NIF=XXXXXXXXX
COMPANY_NAME=Nombre de tu empresa
COMPANY_ADDRESS=Calle y número
COMPANY_POSTAL_CODE=00000
COMPANY_CITY=Ciudad
COMPANY_PROVINCE=Provincia
COMPANY_COUNTRY=España
